						"body": {
							"mode": "raw",
							"raw": "{\n  \"walletId\": \"00000000-0000-0000-0000-000000000001\",\n  \"amount\": 500\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/Transaction/deposit",
							"host": ["{{baseUrl}}"],
							"path": ["api", "Transaction", "deposit"]
						}
					},
					"response": {
						"status": "No Content",
						"code": 204
					}
				},
				{
					"name": "Withdraw",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"walletId\": \"00000000-0000-0000-0000-000000000001\",\n  \"amount\": 200\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/Transaction/withdraw",
							"host": ["{{baseUrl}}"],
							"path": ["api", "Transaction", "withdraw"]
						}
					},
					"response": {
						"status": "No Content",
						"code": 204
					}
				},
				{
					"name": "Transfer",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"fromWalletId\": \"00000000-0000-0000-0000-000000000001\",\n  \"toWalletId\": \"00000000-0000-0000-0000-000000000002\",\n  \"amount\": 300\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/Transaction/transfer",
							"host": ["{{baseUrl}}"],
							"path": ["api", "Transaction", "transfer"]
						}
					},
					"response": {
						"status": "No Content",
						"code": 204
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	]
}

